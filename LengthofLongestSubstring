class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        char_map = {}  # Stores the last seen index of each character
        max_length = 0
        start = 0      # Left pointer of the sliding window

        for end in range(len(s)):
            # If character is already in the window, move the start pointer
            if s[end] in char_map and char_map[s[end]] >= start:
                start = char_map[s[end]] + 1
            
            # Update the character's last seen position
            char_map[s[end]] = end
            
            # Calculate window size and update max_length
            max_length = max(max_length, end - start + 1)
            
        return max_length
