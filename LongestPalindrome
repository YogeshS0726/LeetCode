class Solution:
    def longestPalindrome(self, s: str) -> str:
        if not s:
            return ""
        
        res = ""
        for i in range(len(s)):
            # Odd length palindromes (center is a character: "aba")
            p1 = self.expand(s, i, i)
            # Even length palindromes (center is between characters: "abba")
            p2 = self.expand(s, i, i + 1)
            
            # Keep the longest result found so far
            res = max(res, p1, p2, key=len)
            
        return res

    def expand(self, s: str, left: int, right: int) -> str:
        # Expand outwards as long as it's a palindrome
        while left >= 0 and right < len(s) and s[left] == s[right]:
            left -= 1
            right += 1
        # Return the valid palindrome substring
        return s[left + 1:right]
